# Bee Incubation — ZI02 VOC sensor service configuration
# Copy to /etc/vapsens/vapsens.conf and fill in the values, then:
#   sudo systemctl restart vapsens
#
# This file is read by systemd (EnvironmentFile) — KEY=VALUE, no quotes, no spaces.

# --- Required ---
# Tailscale IP (or MagicDNS name) of the computer running the incubation app,
# plus the QR-server port (default 5151). Find the app computer's Tailscale IP
# with `tailscale ip -4` on that machine.
APP_URL=http://100.x.y.z:5151

# --- Optional (sensible defaults if omitted) ---
# Must match the app's Settings -> "voc_ingest_token". Leave blank if the app
# has no token set (open ingest on the Tailscale network).
INGEST_TOKEN=

# Incubator/position are now assigned FROM THE APP (Settings -> Vapona Sensors).
# The Pi reports a stable HARDWARE_ID and the app maps it to an incubator and
# slot, so you normally leave the two lines below blank/commented. They are used
# only as a one-time seed if this device has never been seen by the app before.
#INCUBATOR_ID=7
#POSITION=front

# Override the auto-detected hardware id (normally leave blank — the service
# derives a stable id from the Pi serial / machine-id).
#HARDWARE_ID=

# Friendly identifier for this sensor (defaults to the Pi hostname).
SENSOR_ID=vapsens-zi02

# Serial device and baud (defaults match the confirmed ZI02 wiring).
SERIAL_PORT=/dev/serial0
BAUD=9600

# Averaging window (seconds) — one stored/synced reading per window.
# Sensor streams ~1 Hz; 900s (15 min) matches the temperature poll interval
# and stores a smoothed 15-minute average. Lower it for finer resolution.
SAMPLE_SECONDS=900

# How often to check for / push new buffered readings to the app (seconds).
SYNC_SECONDS=60

# Drop already-synced buffer rows older than this many days.
PRUNE_DAYS=14

# Local buffer database path (must be writable by the service user).
BUFFER_DB=/var/lib/vapsens/buffer.db
