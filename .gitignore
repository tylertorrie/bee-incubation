# Database — synced separately via Google Drive / cloud, NOT via git
*.db
*.db-shm
*.db-wal

# Local config — stores per-machine DB path, not shared via git
incubation_config.json

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Log files — local to each machine
*.log

# Desktop shortcut / icon artefacts
# (logo.png and app_icon.png are tracked — they're the source assets)
*.ico
*.lnk
*.ps1
# Raw icon drop (superseded by app_icon.png)
Bee-JPG (3).jpg

# VS Code / editor folders
.vscode/
.idea/

# OS files
Thumbs.db
.DS_Store

# Google Calendar OAuth token (local secret)
gcal_token.json
